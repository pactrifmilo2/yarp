    },
    {
      "name": "Control Plane — Audit",
      "item": [
        {
          "name": "List audit entries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{adminBaseUrl}}/api/control/audit-entries?take=50",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "api",
                "control",
                "audit-entries"
              ],
              "query": [
                {
                  "key": "take",
                  "value": "50",
                  "description": "1–500, default 100"
